{
  "version": 2,
  "outputDirectory": "public",
  "rewrites": [
    { "source": "/api/:path*",     "destination": "/api/index"  },
    { "source": "/project/:path*", "destination": "/index.html" },
    { "source": "/admin",          "destination": "/admin.html"       },
    { "source": "/admin-login",    "destination": "/admin-login.html" }
  ]
}
